# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string for the backend API (Prisma).
# In Vercel, create a Postgres database under Storage — this gets injected automatically.
# For local dev, point it at a local/dev Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/antam"

# JWT_SECRET: Long random string used to sign login tokens. Generate one and keep it secret.
JWT_SECRET="MY_JWT_SECRET"

# Google Sheets sync (mirrors registered accounts into an Admin-owned spreadsheet).
# Create a Google Service Account, download its JSON key, then share the target
# Sheet with the service account's client_email as an Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL="my-service-account@my-project.iam.gserviceaccount.com"
# Paste the JSON key's "private_key" value; keep the \n escape sequences as-is.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
# Spreadsheet ID from its URL (defaults to the shared AN TÂM accounts sheet if unset).
ACCOUNTS_SHEET_ID="1XYxVFmb48osTSmE1DJ2N9AEZYgbdQUjpmcITGTv7vCA"
# Tab name inside the spreadsheet to write to (defaults to "Sheet1").
ACCOUNTS_SHEET_TAB_NAME="Sheet1"
# Optional shared secret required in the x-sync-secret header (light deterrent only).
ACCOUNTS_SHEET_SYNC_SECRET="MY_SYNC_SECRET"
